      </ul>
    </header>
    <main>
        <div class="archive-header">
            <a href="https://hamweekly.com/"><img src="https://hamweekly.com/images/amateur-radio-weekly.gif" width="700"></a>
        </div>
        <div class="archive-content">
            {{ content | safe }}
        </div>
    </main>
    <footer>
      <p>Copyright &copy; {% year %} A Midnight Cheese Production</p>
      <p><a href="/about/" title="About Amateur Radio Weekly">About</a> | <a href="/archive/" title="Links to all issues">Archive</a> | <a href="https://daily.hamweekly.com/">Daily News</a> | <a href="/links/">Links</a> | <a href="https://netfinder.radio/">Net Finder</a> | <a href="http://hamweekly.com/rss/issues.xml" title="RSS feed">RSS</a></p>
