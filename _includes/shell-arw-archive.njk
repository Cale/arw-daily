    <meta name="description" content="Issue {{ issue }} of Amateur Radio Weekly features {{ subject }}">
    <meta name="robots" content="index,follow">
    <meta name="author" content="K4HCK Cale">
    <link rel="canonical" href="https://hamweekly.com/archive/issues/amateur-radio-weekly-issue-{{ issue }}.html">
    <meta property="og:title" content="{{ subject }} - Amateur Radio Weekly - Issue {{ issue }}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://hamweekly.com/archive/issues/amateur-radio-weekly-issue-{{ issue }}.html">
